From 14ab755235a3850bd0fbf250c7e75bd30734ec1a Mon Sep 17 00:00:00 2001
From: Todor Trundev <trundev@gmail.com>
Date: Sat, 30 Dec 2023 16:54:09 +0200
Subject: [PATCH 1/1] Initial "terrain ridge" style, using [size]

Use an explicitly enumerated [size=<l>] property to separate ridges by
extent.
---
 data/mapcss-mapping.csv                       |  9 +++++
 data/styles/clear/include/Basemap.mapcss      | 39 +++++++++++++++++++
 .../clear/include/priorities_3_FG.prio.txt    | 18 +++++++++
 .../include/priorities_4_overlays.prio.txt    |  9 +++++
 data/styles/clear/style-clear/colors.mapcss   |  6 +++
 data/styles/clear/style-night/colors.mapcss   |  6 +++
 .../outdoors/include/priorities_3_FG.prio.txt | 18 +++++++++
 .../include/priorities_4_overlays.prio.txt    |  9 +++++
 8 files changed, 114 insertions(+)

diff --git a/data/mapcss-mapping.csv b/data/mapcss-mapping.csv
index b210ff29..4c859cbc 100644
--- a/data/mapcss-mapping.csv
+++ b/data/mapcss-mapping.csv
@@ -1679,3 +1679,12 @@ amenity|compressed_air;1592;
 leisure|hackerspace;1593;
 railway|station|subway|singapore;[railway=station][transport=subway][city=singapore],[railway=station][station=subway][city=singapore];;name;int_name;1594;
 railway|subway_entrance|singapore;[railway=subway_entrance][city=singapore];;name;int_name;1595;
+natural|ridge|size|6;[natural=ridge][size=6],[natural=ridge][size=5],[natural=ridge][size=4],[natural=ridge][size=3],[natural=ridge][size=2],[natural=ridge][size=1];;name;int_name;1596;
+natural|ridge|size|7;[natural=ridge][size=7];;name;int_name;1597;
+natural|ridge|size|8;[natural=ridge][size=8];;name;int_name;1598;
+natural|ridge|size|9;[natural=ridge][size=9];;name;int_name;1599;
+natural|ridge|size|10;[natural=ridge][size=10];;name;int_name;1600;
+natural|ridge|size|11;[natural=ridge][size=11];;name;int_name;1601;
+natural|ridge|size|12;[natural=ridge][size=12];;name;int_name;1602;
+natural|ridge|size|13;[natural=ridge][size=13];;name;int_name;1603;
+natural|ridge|size|14;[natural=ridge][size=14];;name;int_name;1604;
diff --git a/data/styles/clear/include/Basemap.mapcss b/data/styles/clear/include/Basemap.mapcss
index e67702fb..1c08145b 100644
--- a/data/styles/clear/include/Basemap.mapcss
+++ b/data/styles/clear/include/Basemap.mapcss
@@ -694,3 +694,42 @@ line|z18-[isoline=step_50],
 line|z18-[isoline=zero],
 line|z18-[isoline=step_10],
 {width: 1.3;opacity: 0.8;}
+
+/* 9.x TERRAIN RIDGES */
+/* width is <z> - <size> */
+
+line|z10[natural=ridge][size=10],
+line|z11[natural=ridge][size=11],
+line|z12[natural=ridge][size=12],
+line|z13[natural=ridge][size=13],
+line|z14[natural=ridge][size=14],
+{color: @ridge;width: .5;opacity: 0.8;dashes: 10,5;}
+line|z10[natural=ridge][size=9],
+line|z11[natural=ridge][size=10],
+line|z12[natural=ridge][size=11],
+line|z13[natural=ridge][size=12],
+line|z14[natural=ridge][size=13],
+line|z15-[natural=ridge][size=14],
+{color: @ridge;width: 1;opacity: 0.8;}
+line|z9[natural=ridge][size=7],
+line|z10[natural=ridge][size=8],
+line|z11[natural=ridge][size=9],
+line|z12[natural=ridge][size=10],
+line|z13[natural=ridge][size=11],
+line|z14[natural=ridge][size=12],
+line|z15-[natural=ridge][size=13],
+{
+  color: @ridge;width: 2;opacity: 0.8;
+  text:name;font-size: 9;fill-opacity: 0.7;text-color: @label_ridge;text-position: line;
+}
+line|z9-[natural=ridge][size<=6],
+line|z10-[natural=ridge][size=7],
+line|z11-[natural=ridge][size=8],
+line|z12-[natural=ridge][size=9],
+line|z13-[natural=ridge][size=10],
+line|z14-[natural=ridge][size=11],
+line|z15-[natural=ridge][size=12],
+{
+  color: @ridge;width: 3;opacity: 0.8;casing-width: 1;casing-color: @ridge_casing;
+  text:name;font-size: 9;fill-opacity: 0.7;text-color: @label_ridge;text-position: line;
+}
